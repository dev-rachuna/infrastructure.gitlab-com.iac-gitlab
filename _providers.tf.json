{
  "terraform": {
    "required_version": ">= 1.10.5",
    "required_providers": {
      "gitlab": {
        "source": "gitlabhq/gitlab",
        "version": "18.11.0"
      },
      "vault": {
        "source": "hashicorp/vault",
        "version": "5.6.0"
      }
    },
    "backend": {
      "http": {}
    }
  },
  "provider": {
    "gitlab": {
      "insecure": true
    },
    "vault": {
      "skip_tls_verify": true
    }
  }
}
