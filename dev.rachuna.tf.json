{
  "module": {
    "_dev_rachuna": {
      "source": "git::https://gitlab.com/dev.rachuna/artifacts/opentofu/gitlab-group.git?ref=1.0.0",
      "parent_group": "${local.parent_name}",
      "name": "dev.rachuna",
      "description": "https://rachuna.dev",
      "visibility": "public",
      "default_branch": "main",
      "avatar": "images/dev.rachuna.png",
      "labels": "${jsondecode(file(\"${path.module}/data/labels.json\"))}",
      "badges": "${jsondecode(file(\"${path.module}/data/badges.json\"))}",
      "members": {
        "mrachuna": {
          "access_level": "owner"
        },
        "service_account_group_132728705_fb584644d5d6365926bda0215444c352": {
          "access_level": "owner"
        }
      },
      "variables": {
        "GITLAB_OBSERVABILITY_EXPORT": {
          "description": "Gitlab Observability",
          "value": "traces,metrics,logs"
        },
        "VAULT_ADDR": {
          "description": "Adres serwera Vault",
          "value": "https://vault.rachuna.dev"
        },
        "VAULT_TOKEN": {
          "description": "Token dostępu do Vault",
          "value": "${data.vault_generic_secret.auth_vault.data[\"VAULT_TOKEN\"]}"
        },
        "GITLAB_TOKEN": {
          "description": "Token dostępu do Gitlab API",
          "value": "${data.vault_generic_secret.auth_gitlab.data[\"GITLAB_TOKEN\"]}"
        },
        "GITLAB_SSH_KEY": {
          "description": "Klucz SSH do repozytorium Gitlab",
          "value": "${data.vault_generic_secret.auth_gitlab.data[\"GITLAB_SSH_KEY\"]}"
        }
      }
    },
    "dev_rachuna": {
      "source": "./dev.rachuna/"
    }
  }
}
